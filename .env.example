# ── Mode Selection ───────────────────────────────────────────────────────────
TRADE_MODE=paper              # 'paper' | 'live'
TRADE_INSTRUMENT=equity       # 'equity' | 'options'

# ── Upstox Broker ────────────────────────────────────────────────────────────
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=
UPSTOX_ACCESS_TOKEN=          # Refresh daily via Upstox OAuth — short-lived token

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/sd_bot

# ── Equity Capital (used when TRADE_INSTRUMENT=equity) ───────────────────────
CAPITAL=100000
CAPITAL_MODE=risk             # 'fixed' | 'percent' | 'risk'
CAPITAL_PER_TRADE=10000       # used when CAPITAL_MODE=fixed
CAPITAL_PCT_PER_TRADE=10      # used when CAPITAL_MODE=percent
MAX_RISK_PER_TRADE_PCT=2      # used when CAPITAL_MODE=risk (% of CAPITAL)
MAX_DAILY_LOSS_PCT=6          # stop trading for the day after this % loss

# ── Options Capital (used when TRADE_INSTRUMENT=options) ─────────────────────
OPTIONS_CAPITAL=20000         # total capital allocated to options
OPTIONS_RISK_PCT=1            # max loss per trade as % of OPTIONS_CAPITAL
OPTIONS_MAX_PREMIUM_PCT=10    # % of OPTIONS_CAPITAL to spend on premium per trade
OPTIONS_MAX_TRADES=10         # max paper trades per day
